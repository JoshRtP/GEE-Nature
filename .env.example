# ============================================================
# TerraNexus Co-benefit Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ----------------------------------------------------------
# REQUIRED: Supabase (Phase 1 + all phases)
# ----------------------------------------------------------
# From: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ----------------------------------------------------------
# OPTIONAL: GEE OAuth (DEPRECATED — do not use)
# ----------------------------------------------------------
# The OAuth browser flow was removed because Google deprecated
# the implicit grant for Earth Engine in 2022.
# All GEE computation is now server-side.
# VITE_GEE_OAUTH_CLIENT_ID=  ← intentionally empty
